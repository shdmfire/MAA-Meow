{
  "projectDependencyRules": [
    {
      "from": ":automation:*",
      "forbid": ":controller:*",
      "enabledFromPhase": 0,
      "description": "automation modules must not depend on controller modules",
      "suggestion": "depend on a controller-neutral contract module; controller implementations may depend inward on that contract"
    },
    {
      "from": ":feature:control-shell",
      "forbid": ":controller:*",
      "enabledFromPhase": 0,
      "description": "the control shell must not depend on controller implementations",
      "suggestion": "resolve controllers through the plugin/registry contract instead of a project dependency"
    }
  ],
